{{!
    @template local_educheckout/product

    Single product page with image, description, tags, variation chooser and add-to-cart form.

    Example context (json):
    {
        "id": 1,
        "fullname": "Course A",
        "price": "10.00",
        "imageurl": "",
        "hasdescription": true,
        "description": "<p>Learn something great.</p>",
        "hastags": true,
        "tags": [{"label": "compliance"}],
        "categoryname": "Compliance",
        "hascategoryname": true,
        "hasvariations": true,
        "variations": [{"id": 5, "name": "Standard", "price": "10.00", "hassessiondata": false,
            "session_starttime_formatted": "", "session_endtime_formatted": "",
            "session_location": "", "seats_text": "", "is_full": false}],
        "addurl": "https://example.com/local/educheckout/cart.php",
        "catalogueurl": "https://example.com/local/educheckout/index.php",
        "sesskey": "abc123"
    }
}}
<div class="local-educheckout-product-detail row">
    <div class="col-12 col-md-5 mb-4">
        {{#imageurl}}
        <img src="{{imageurl}}" class="img-fluid rounded" alt="{{fullname}}">
        {{/imageurl}}
        {{^imageurl}}
        <div class="local-educheckout-product-detail__img-placeholder d-flex align-items-center justify-content-center bg-light rounded" style="height:280px">
            <span class="display-4 text-muted">&#127979;</span>
        </div>
        {{/imageurl}}
    </div>

    <div class="col-12 col-md-7">
        <a href="{{catalogueurl}}" class="text-muted small">&larr; {{#str}}catalogue, local_educheckout{{/str}}</a>

        {{#hascategoryname}}
        <p class="text-muted mt-2 mb-1">{{categoryname}}</p>
        {{/hascategoryname}}

        <h2 class="mt-1">{{fullname}}</h2>

        {{#hastags}}
        <div class="local-educheckout-product-detail__tags mb-3">
            {{#tags}}
            <span class="badge badge-light border">{{label}}</span>
            {{/tags}}
        </div>
        {{/hastags}}

        {{#hasdescription}}
        <div class="local-educheckout-product-detail__description mb-4">
            {{{description}}}
        </div>
        {{/hasdescription}}

        {{#alreadyenrolled}}
        <div class="alert alert-success">
            {{#str}}alreadyenrolled, local_educheckout{{/str}}
            <a href="{{courseurl}}" class="alert-link">{{#str}}gotocourse, local_educheckout{{/str}}</a>
        </div>
        {{/alreadyenrolled}}

        {{^alreadyenrolled}}
        <form method="post" action="{{addurl}}" data-educheckout="add-form">
            <input type="hidden" name="action" value="add">
            <input type="hidden" name="product" value="{{id}}">
            <input type="hidden" name="sesskey" value="{{sesskey}}">

            {{#hasvariations}}
            <fieldset class="local-educheckout-variations mb-3">
                <legend class="h6">{{#str}}selectvariation, local_educheckout{{/str}}</legend>
                {{#variations}}
                <div class="form-check{{#is_full}} local-moodec-session--full{{/is_full}}">
                    <input class="form-check-input" type="radio" name="variation" value="{{id}}" id="var-{{id}}"{{#is_full}} disabled{{/is_full}}>
                    <label class="form-check-label{{#is_full}} text-muted{{/is_full}}" for="var-{{id}}">
                        {{name}} &mdash; <strong>{{price}}</strong>
                        {{#hassessiondata}}
                        <span class="d-block text-muted small">
                            {{session_starttime_formatted}}{{#session_endtime_formatted}} &ndash; {{session_endtime_formatted}}{{/session_endtime_formatted}}
                            {{#session_location}}&bull; {{session_location}}{{/session_location}}
                        </span>
                        <span class="d-block small">{{seats_text}}</span>
                        {{/hassessiondata}}
                    </label>
                </div>
                {{/variations}}
            </fieldset>
            {{/hasvariations}}
            {{^hasvariations}}
            <p class="local-educheckout-price h4 text-primary mb-3">{{price}}</p>
            <input type="hidden" name="variation" value="0">
            {{/hasvariations}}

            <button type="submit" class="btn btn-primary btn-lg">{{#str}}addtocart, local_educheckout{{/str}}</button>
        </form>
        {{/alreadyenrolled}}
    </div>
</div>
