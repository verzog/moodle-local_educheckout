{{!
    @template local_moodec/product

    Single product page with an add-to-cart form.

    Example context (json):
    {
        "id": 1,
        "fullname": "Course A",
        "price": "10.00",
        "addurl": "https://example.com/local/moodec/cart.php",
        "sesskey": "abc123"
    }
}}
<div class="local-moodec-product-detail">
    <p class="local-moodec-price">{{#str}}price, local_moodec{{/str}}: {{price}}</p>
    <form method="post" action="{{addurl}}">
        <input type="hidden" name="action" value="add">
        <input type="hidden" name="product" value="{{id}}">
        <input type="hidden" name="sesskey" value="{{sesskey}}">
        <button type="submit" class="btn btn-primary">{{#str}}addtocart, local_moodec{{/str}}</button>
    </form>
</div>
