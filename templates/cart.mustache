{{!
    @template local_moodec/cart

    Shopping cart contents.

    Example context (json):
    {
        "isempty": false,
        "items": [{"id": 1, "name": "Course A", "unitprice": "10.00", "sesskey": "abc", "removeurl": "x"}],
        "total": "10.00",
        "checkouturl": "x",
        "shopurl": "y"
    }
}}
<div class="local-moodec-cart">
    {{#isempty}}
    <p>{{#str}}cart_empty, local_moodec{{/str}}</p>
    <p><a href="{{shopurl}}">{{#str}}continueshopping, local_moodec{{/str}}</a></p>
    {{/isempty}}
    {{^isempty}}
    <ul class="local-moodec-cart-items">
        {{#items}}
        <li>
            <span>{{name}}</span>
            <span class="local-moodec-price">{{unitprice}}</span>
            <form method="post" action="{{removeurl}}" data-moodec="remove-form">
                <input type="hidden" name="action" value="remove">
                <input type="hidden" name="item" value="{{id}}">
                <input type="hidden" name="sesskey" value="{{sesskey}}">
                <button type="submit" class="btn btn-link">{{#str}}remove, local_moodec{{/str}}</button>
            </form>
        </li>
        {{/items}}
    </ul>
    <p class="local-moodec-total">{{#str}}total, local_moodec{{/str}}: <span data-moodec="total">{{total}}</span></p>
    <p><a class="btn btn-primary" href="{{checkouturl}}">{{#str}}checkout, local_moodec{{/str}}</a></p>
    {{/isempty}}
</div>
