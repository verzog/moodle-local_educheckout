{{!
    @template local_educheckout/checkout

    Checkout summary with itemised cart, tax breakdown, optional gateway
    surcharge, and the core payment trigger button.

    Example context (json):
    {
        "amount": "112.45",
        "currency": "AUD",
        "cost": "$112.45",
        "component": "local_educheckout",
        "paymentarea": "cart",
        "itemid": 1,
        "description": "Checkout",
        "successurl": "https://example.com/local/educheckout/receipt.php?id=1",
        "hasitems": true,
        "items": [{"coursename": "Introduction to Work Safety", "unitprice": "110.00"}],
        "hastax": true,
        "taxlabel": "GST",
        "netamount": "100.00",
        "taxamount": "10.00",
        "hasgatewayfee": true,
        "gatewayfeelabel": "Card processing fee",
        "gatewayfeeamount": "2.45"
    }
}}
<div class="local-educheckout-checkout">
    {{#hasitems}}
    <table class="table table-striped table-sm align-middle local-educheckout-checkout__items mb-3">
        <thead>
            <tr>
                <th scope="col">{{#str}}product_course, local_educheckout{{/str}}</th>
                <th scope="col">{{#str}}product_description, local_educheckout{{/str}}</th>
                <th scope="col" class="text-end">{{#str}}price, local_educheckout{{/str}}</th>
            </tr>
        </thead>
        <tbody>
            {{#items}}
            <tr>
                <td class="fw-semibold">{{coursename}}</td>
                <td class="text-muted small">{{#hassummary}}{{summary}}{{/hassummary}}</td>
                <td class="text-end text-nowrap">{{currency}}&nbsp;{{unitprice}}</td>
            </tr>
            {{/items}}
        </tbody>
    </table>
    {{/hasitems}}
    {{#hastax}}
    <p class="d-flex justify-content-between mb-1">
        <span>{{#str}}subtotal, local_educheckout{{/str}}</span>
        <span>{{currency}}&nbsp;{{netamount}}</span>
    </p>
    <p class="d-flex justify-content-between mb-1">
        <span>{{taxlabel}}</span>
        <span>{{currency}}&nbsp;{{taxamount}}</span>
    </p>
    {{/hastax}}
    {{#hasgatewayfee}}
    <p class="d-flex justify-content-between mb-1 local-educheckout-checkout__fee">
        <span>{{gatewayfeelabel}}</span>
        <span>{{currency}}&nbsp;{{gatewayfeeamount}}</span>
    </p>
    {{/hasgatewayfee}}
    <p class="d-flex justify-content-between fw-bold local-educheckout-total mb-3">
        <span>{{#str}}total, local_educheckout{{/str}}</span>
        <span>{{currency}}&nbsp;{{amount}}</span>
    </p>
    <button
        class="btn btn-primary"
        type="button"
        data-action="core_payment/triggerPayment"
        data-component="{{component}}"
        data-paymentarea="{{paymentarea}}"
        data-itemid="{{itemid}}"
        data-cost="{{cost}}"
        data-successurl="{{successurl}}"
        data-description="{{description}}"
    >{{#str}}pay, local_educheckout{{/str}}</button>
</div>
