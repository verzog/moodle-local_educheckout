{{!
    @template local_moodec/variation_list

    Table of product variations on the product edit page.

    Example context (json):
    {
        "hasvariations": true,
        "is_session_product": false,
        "variations": [{"id":1,"name":"Standard","price":"99.00","duration":365,"is_enabled":true,
            "session_starttime_formatted":"","session_endtime_formatted":"",
            "session_location":"","session_capacity":0,"editurl":"","deleteurl":""}]
    }
}}
{{#hasvariations}}
<table class="table table-sm table-bordered mb-3">
    <thead class="thead-light">
        <tr>
            <th>{{#str}}variation_name, local_moodec{{/str}}</th>
            <th>{{#str}}variation_price, local_moodec{{/str}}</th>
            <th>{{#str}}variation_duration, local_moodec{{/str}}</th>
            {{#is_session_product}}
            <th>{{#str}}variation_session_starttime, local_moodec{{/str}}</th>
            <th>{{#str}}variation_session_endtime, local_moodec{{/str}}</th>
            <th>{{#str}}session_location, local_moodec{{/str}}</th>
            <th>{{#str}}session_capacity, local_moodec{{/str}}</th>
            {{/is_session_product}}
            <th>{{#str}}product_status, local_moodec{{/str}}</th>
            <th>{{#str}}actions, local_moodec{{/str}}</th>
        </tr>
    </thead>
    <tbody>
        {{#variations}}
        <tr>
            <td>{{name}}</td>
            <td>{{price}}</td>
            <td>{{duration}}</td>
            {{#is_session_product}}
            <td>{{session_starttime_formatted}}</td>
            <td>{{session_endtime_formatted}}</td>
            <td>{{session_location}}</td>
            <td>{{session_capacity}}</td>
            {{/is_session_product}}
            <td>
                {{#is_enabled}}<span class="badge badge-success">{{#str}}product_enabled_yes, local_moodec{{/str}}</span>{{/is_enabled}}
                {{^is_enabled}}<span class="badge badge-secondary">{{#str}}product_enabled_no, local_moodec{{/str}}</span>{{/is_enabled}}
            </td>
            <td class="d-flex gap-1">
                <a href="{{editurl}}" class="btn btn-sm btn-outline-primary">{{#str}}edit{{/str}}</a>
                <a href="{{deleteurl}}" class="btn btn-sm btn-outline-danger"
                   onclick="return confirm('{{#str}}variation_delete_confirm, local_moodec{{/str}}')">
                    {{#str}}delete{{/str}}
                </a>
            </td>
        </tr>
        {{/variations}}
    </tbody>
</table>
{{/hasvariations}}
{{^hasvariations}}
<p class="text-muted">{{#str}}variations_none, local_moodec{{/str}}</p>
{{/hasvariations}}
