{{!
    @template local_moodec/category_list

    Category listing on the category management page.

    Example context (json):
    {
        "hascategories": true,
        "categories": [{"id":1,"name":"Compliance","sortorder":0,"editurl":"","deleteurl":""}],
        "manageurl": "https://example.com/local/moodec/manage.php"
    }
}}
<div class="local-moodec-categories mb-3">
    <a href="{{manageurl}}" class="btn btn-secondary mb-3">&larr; {{#str}}manage_title, local_moodec{{/str}}</a>

    {{#hascategories}}
    <table class="table table-bordered table-hover">
        <thead class="thead-light">
            <tr>
                <th>{{#str}}category_name, local_moodec{{/str}}</th>
                <th>{{#str}}category_sortorder, local_moodec{{/str}}</th>
                <th>{{#str}}actions, local_moodec{{/str}}</th>
            </tr>
        </thead>
        <tbody>
            {{#categories}}
            <tr>
                <td>{{name}}</td>
                <td>{{sortorder}}</td>
                <td class="d-flex gap-1">
                    <a href="{{editurl}}" class="btn btn-sm btn-outline-primary">{{#str}}edit{{/str}}</a>
                    <a href="{{deleteurl}}" class="btn btn-sm btn-outline-danger">{{#str}}delete{{/str}}</a>
                </td>
            </tr>
            {{/categories}}
        </tbody>
    </table>
    {{/hascategories}}
    {{^hascategories}}
    <p class="text-muted">{{#str}}categories_none, local_moodec{{/str}}</p>
    {{/hascategories}}
</div>
