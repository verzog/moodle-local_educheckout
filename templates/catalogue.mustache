{{!
    @template local_educheckout/catalogue

    Catalogue card grid with category filter and pagination.

    Example context (json):
    {
        "hascategories": true,
        "categories": [{"id":1,"name":"Compliance","active":false,"url":""}],
        "allcaturl": "",
        "allcatactive": true,
        "hasproducts": true,
        "products": [{"id":1,"fullname":"Course A","price":"From $10.00","imageurl":"","hastags":true,"tags":[{"label":"php"}],"producturl":"https://example.com/local/educheckout/product.php?id=1","categoryname":"Compliance","hascategoryname":true,"candirectadd":true,"directvariationid":0,"purchased":false,"courseurl":"https://example.com/course/view.php?id=2"}],
        "carturl": "",
        "addurl": "https://example.com/local/educheckout/cart.php",
        "sesskey": "sesskey",
        "cartcount": 2,
        "hascartitems": true,
        "haspagination": true,
        "prevurl": "",
        "nexturl": "",
        "page": 1,
        "totalpages": 3,
        "hasprev": false,
        "hasnext": true
    }
}}
<div class="local-educheckout-catalogue">

    <div class="local-educheckout-catalogue__toolbar d-flex justify-content-between align-items-center mb-3">
        <div>
            <a href="{{carturl}}" class="btn btn-outline-secondary">
                &#128722; {{#str}}cart_title, local_educheckout{{/str}}{{#hascartitems}} <span class="badge badge-primary local-educheckout-cart-count">{{cartcount}}</span>{{/hascartitems}}
            </a>
        </div>
    </div>

    {{#hascategories}}
    <nav class="local-educheckout-catalogue__categories mb-4" aria-label="{{#str}}catalogue_categories, local_educheckout{{/str}}">
        <ul class="nav nav-pills flex-wrap">
            <li class="nav-item">
                <a class="nav-link{{#allcatactive}} active{{/allcatactive}}" href="{{allcaturl}}">
                    {{#str}}catalogue_all, local_educheckout{{/str}}
                </a>
            </li>
            {{#categories}}
            <li class="nav-item">
                <a class="nav-link{{#active}} active{{/active}}" href="{{url}}">{{name}}</a>
            </li>
            {{/categories}}
        </ul>
    </nav>
    {{/hascategories}}

    {{#hasproducts}}
    <div class="local-educheckout-catalogue__grid row">
        {{#products}}
        <div class="col-12 col-sm-6 col-md-4 col-lg-3 mb-4">
            <div class="card h-100 local-educheckout-product-card">
                <div class="position-relative">
                    {{#purchased}}
                    <span class="badge badge-success local-educheckout-product-card__purchased" style="position:absolute;top:.5rem;left:.5rem;z-index:1;">{{#str}}purchased, local_educheckout{{/str}}</span>
                    {{/purchased}}
                    {{#imageurl}}
                    <img src="{{imageurl}}" class="card-img-top local-educheckout-product-card__img" alt="{{fullname}}">
                    {{/imageurl}}
                    {{^imageurl}}
                    <div class="local-educheckout-product-card__img-placeholder d-flex align-items-center justify-content-center bg-light" style="height:160px">
                        <span class="text-muted">&#127979;</span>
                    </div>
                    {{/imageurl}}
                </div>
                <div class="card-body d-flex flex-column">
                    {{#hascategoryname}}
                    <p class="card-subtitle mb-1 text-muted small">{{categoryname}}</p>
                    {{/hascategoryname}}
                    <h5 class="card-title">
                        <a href="{{producturl}}" class="text-dark text-decoration-none">{{fullname}}</a>
                    </h5>
                    {{#hastags}}
                    <div class="local-educheckout-product-card__tags mb-2">
                        {{#tags}}
                        <span class="badge badge-light border">{{label}}</span>
                        {{/tags}}
                    </div>
                    {{/hastags}}
                    <div class="mt-auto">
                        <span class="local-educheckout-product-card__price h5 text-primary d-block mb-2">{{price}}</span>
                        {{#purchased}}
                        <a href="{{courseurl}}" class="btn btn-success btn-sm w-100">{{#str}}gotocourse, local_educheckout{{/str}}</a>
                        {{/purchased}}
                        {{^purchased}}
                        {{#candirectadd}}
                        <form method="post" action="{{addurl}}" data-educheckout="add-form">
                            <input type="hidden" name="action" value="add">
                            <input type="hidden" name="product" value="{{id}}">
                            <input type="hidden" name="variation" value="{{directvariationid}}">
                            <input type="hidden" name="sesskey" value="{{sesskey}}">
                            <button type="submit" class="btn btn-primary btn-sm w-100">{{#str}}addtocart, local_educheckout{{/str}}</button>
                        </form>
                        {{/candirectadd}}
                        {{^candirectadd}}
                        <a href="{{producturl}}" class="btn btn-outline-primary btn-sm w-100">{{#str}}viewoptions, local_educheckout{{/str}}</a>
                        {{/candirectadd}}
                        {{/purchased}}
                    </div>
                </div>
            </div>
        </div>
        {{/products}}
    </div>
    {{/hasproducts}}
    {{^hasproducts}}
    <p class="text-muted">{{#str}}catalogue_empty, local_educheckout{{/str}}</p>
    {{/hasproducts}}

    {{#haspagination}}
    <nav class="local-educheckout-catalogue__pagination mt-4" aria-label="{{#str}}pagination_label, local_educheckout{{/str}}">
        <ul class="pagination justify-content-center">
            <li class="page-item{{^hasprev}} disabled{{/hasprev}}">
                <a class="page-link" href="{{prevurl}}">&laquo; {{#str}}previous, local_educheckout{{/str}}</a>
            </li>
            <li class="page-item disabled">
                <span class="page-link">{{page}} / {{totalpages}}</span>
            </li>
            <li class="page-item{{^hasnext}} disabled{{/hasnext}}">
                <a class="page-link" href="{{nexturl}}">{{#str}}next, local_educheckout{{/str}} &raquo;</a>
            </li>
        </ul>
    </nav>
    {{/haspagination}}

</div>
