{{!
    @template local_moodec/catalogue

    Catalogue card grid with category filter and pagination.

    Example context (json):
    {
        "hascategories": true,
        "categories": [{"id":1,"name":"Compliance","active":false,"url":""}],
        "allcaturl": "",
        "allcatactive": true,
        "hasproducts": true,
        "products": [{"id":1,"fullname":"Course A","price":"10.00","imageurl":"","hastags":true,"tags":[{"label":"php"}],"producturl":"","categoryname":"Compliance","hascategoryname":true}],
        "carturl": "",
        "haspagination": true,
        "prevurl": "",
        "nexturl": "",
        "page": 1,
        "totalpages": 3,
        "hasprev": false,
        "hasnext": true
    }
}}
<div class="local-moodec-catalogue">

    <div class="local-moodec-catalogue__toolbar d-flex justify-content-between align-items-center mb-3">
        <div>
            <a href="{{carturl}}" class="btn btn-outline-secondary">
                &#128722; {{#str}}cart_title, local_moodec{{/str}}
            </a>
        </div>
    </div>

    {{#hascategories}}
    <nav class="local-moodec-catalogue__categories mb-4" aria-label="{{#str}}catalogue_categories, local_moodec{{/str}}">
        <ul class="nav nav-pills flex-wrap">
            <li class="nav-item">
                <a class="nav-link{{#allcatactive}} active{{/allcatactive}}" href="{{allcaturl}}">
                    {{#str}}catalogue_all, local_moodec{{/str}}
                </a>
            </li>
            {{#categories}}
            <li class="nav-item">
                <a class="nav-link{{#active}} active{{/active}}" href="{{url}}">{{name}}</a>
            </li>
            {{/categories}}
        </ul>
    </nav>
    {{/hascategories}}

    {{#hasproducts}}
    <div class="local-moodec-catalogue__grid row">
        {{#products}}
        <div class="col-12 col-sm-6 col-md-4 col-lg-3 mb-4">
            <div class="card h-100 local-moodec-product-card">
                {{#imageurl}}
                <img src="{{imageurl}}" class="card-img-top local-moodec-product-card__img" alt="{{fullname}}">
                {{/imageurl}}
                {{^imageurl}}
                <div class="local-moodec-product-card__img-placeholder d-flex align-items-center justify-content-center bg-light" style="height:160px">
                    <span class="text-muted">&#127979;</span>
                </div>
                {{/imageurl}}
                <div class="card-body d-flex flex-column">
                    {{#hascategoryname}}
                    <p class="card-subtitle mb-1 text-muted small">{{categoryname}}</p>
                    {{/hascategoryname}}
                    <h5 class="card-title">
                        <a href="{{producturl}}" class="stretched-link text-dark text-decoration-none">{{fullname}}</a>
                    </h5>
                    {{#hastags}}
                    <div class="local-moodec-product-card__tags mb-2">
                        {{#tags}}
                        <span class="badge badge-light border">{{label}}</span>
                        {{/tags}}
                    </div>
                    {{/hastags}}
                    <div class="mt-auto">
                        <span class="local-moodec-product-card__price h5 text-primary">{{price}}</span>
                    </div>
                </div>
            </div>
        </div>
        {{/products}}
    </div>
    {{/hasproducts}}
    {{^hasproducts}}
    <p class="text-muted">{{#str}}catalogue_empty, local_moodec{{/str}}</p>
    {{/hasproducts}}

    {{#haspagination}}
    <nav class="local-moodec-catalogue__pagination mt-4" aria-label="{{#str}}pagination_label, local_moodec{{/str}}">
        <ul class="pagination justify-content-center">
            <li class="page-item{{^hasprev}} disabled{{/hasprev}}">
                <a class="page-link" href="{{prevurl}}">&laquo; {{#str}}previous, local_moodec{{/str}}</a>
            </li>
            <li class="page-item disabled">
                <span class="page-link">{{page}} / {{totalpages}}</span>
            </li>
            <li class="page-item{{^hasnext}} disabled{{/hasnext}}">
                <a class="page-link" href="{{nexturl}}">{{#str}}next, local_moodec{{/str}} &raquo;</a>
            </li>
        </ul>
    </nav>
    {{/haspagination}}

</div>
