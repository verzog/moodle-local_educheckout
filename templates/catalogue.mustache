{{!
    @template local_moodec/catalogue

    Catalogue listing of saleable courses.

    Example context (json):
    {
        "hasproducts": true,
        "products": [{"id": 1, "fullname": "Course A", "price": "10.00"}],
        "carturl": "https://example.com/local/moodec/cart.php"
    }
}}
<div class="local-moodec-catalogue">
    <p><a href="{{carturl}}">{{#str}}cart_title, local_moodec{{/str}}</a></p>
    {{#hasproducts}}
    <ul class="local-moodec-products">
        {{#products}}
        <li class="local-moodec-product">
            <a href="product.php?id={{id}}">{{fullname}}</a>
            <span class="local-moodec-price">{{price}}</span>
        </li>
        {{/products}}
    </ul>
    {{/hasproducts}}
    {{^hasproducts}}
    <p>{{#str}}cart_empty, local_moodec{{/str}}</p>
    {{/hasproducts}}
</div>
