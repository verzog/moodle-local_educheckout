{{!
    @template local_educheckout/manage_orders

    Order management listing for admins.

    Example context (json):
    {
        "hasorders": true,
        "orders": [{"id":1,"username":"Jane Smith","status":"delivered","amount":"99.00","currency":"AUD","courses":"Course A","date":"18/05/2026 09:00","receipturl":""}],
        "statusfilters": [{"label":"All","url":"","active":true}],
        "haspagination": false,
        "page": 1,
        "totalpages": 1,
        "hasprev": false,
        "hasnext": false,
        "prevurl": "",
        "nexturl": "",
        "manageurl": ""
    }
}}
<div class="local-educheckout-orders">

    <div class="mb-3">
        <a href="{{manageurl}}" class="btn btn-secondary btn-sm">&larr; {{#str}}manage_title, local_educheckout{{/str}}</a>
    </div>

    <nav class="mb-3">
        <ul class="nav nav-pills flex-wrap">
            {{#statusfilters}}
            <li class="nav-item">
                <a class="nav-link{{#active}} active{{/active}}" href="{{url}}">{{label}}</a>
            </li>
            {{/statusfilters}}
        </ul>
    </nav>

    {{#hasorders}}
    <table class="table table-bordered table-hover table-sm">
        <thead class="thead-light">
            <tr>
                <th>#</th>
                <th>{{#str}}orders_student, local_educheckout{{/str}}</th>
                <th>{{#str}}orders_courses, local_educheckout{{/str}}</th>
                <th>{{#str}}orders_amount, local_educheckout{{/str}}</th>
                <th>{{#str}}orders_status, local_educheckout{{/str}}</th>
                <th>{{#str}}orders_date, local_educheckout{{/str}}</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            {{#orders}}
            <tr>
                <td>{{id}}</td>
                <td>{{username}}</td>
                <td><small>{{courses}}</small></td>
                <td>{{currency}} {{amount}}</td>
                <td><span class="badge badge-secondary">{{status}}</span></td>
                <td><small>{{date}}</small></td>
                <td><a href="{{receipturl}}" class="btn btn-sm btn-outline-primary">{{#str}}orders_receipt, local_educheckout{{/str}}</a></td>
            </tr>
            {{/orders}}
        </tbody>
    </table>
    {{/hasorders}}
    {{^hasorders}}
    <p class="text-muted">{{#str}}orders_none, local_educheckout{{/str}}</p>
    {{/hasorders}}

    {{#haspagination}}
    <nav aria-label="{{#str}}pagination_label, local_educheckout{{/str}}">
        <ul class="pagination">
            <li class="page-item{{^hasprev}} disabled{{/hasprev}}">
                <a class="page-link" href="{{prevurl}}">&laquo; {{#str}}previous, local_educheckout{{/str}}</a>
            </li>
            <li class="page-item disabled">
                <span class="page-link">{{page}} / {{totalpages}}</span>
            </li>
            <li class="page-item{{^hasnext}} disabled{{/hasnext}}">
                <a class="page-link" href="{{nexturl}}">{{#str}}next, local_educheckout{{/str}} &raquo;</a>
            </li>
        </ul>
    </nav>
    {{/haspagination}}

</div>
