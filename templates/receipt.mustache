{{!
    @template local_educheckout/receipt

    Order receipt / confirmation.

    Example context (json):
    {
        "delivered": true,
        "amount": "10.00",
        "currency": "AUD",
        "shopurl": "https://example.com/local/educheckout/index.php"
    }
}}
<div class="local-educheckout-receipt">
    {{#delivered}}
    <p>{{#str}}order_complete, local_educheckout{{/str}}</p>
    {{/delivered}}
    {{^delivered}}
    <p>{{#str}}order_pending, local_educheckout{{/str}}</p>
    {{/delivered}}
    <p>{{#str}}total, local_educheckout{{/str}}: {{amount}} {{currency}}</p>
    <p><a href="{{shopurl}}">{{#str}}continueshopping, local_educheckout{{/str}}</a></p>
</div>
