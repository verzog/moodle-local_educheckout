<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/moodec/db" VERSION="2025071600" COMMENT="XMLDB file for Moodle local_moodec plugin" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd">
    <TABLES>
        <TABLE NAME="local_moodec_product" COMMENT="Moodec product settings">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="course_id" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="is_enabled" TYPE="int" LENGTH="1" NOTNULL="false" DEFAULT="0"/>
                <FIELD NAME="variation_count" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0"/>
                <FIELD NAME="type" TYPE="text" NOTNULL="false"/>
                <FIELD NAME="tags" TYPE="text" NOTNULL="false"/>
                <FIELD NAME="description" TYPE="text" NOTNULL="false"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
            </KEYS>
        </TABLE>

        <TABLE NAME="local_moodec_variation" COMMENT="Moodec product variation settings">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="product_id" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="is_enabled" TYPE="int" LENGTH="1" NOTNULL="false" DEFAULT="0"/>
                <FIELD NAME="name" TYPE="text" NOTNULL="false"/>
                <FIELD NAME="price" TYPE="number" LENGTH="10" DECIMALS="2" NOTNULL="false" DEFAULT="0"/>
                <FIELD NAME="duration" TYPE="int" LENGTH="10" NOTNULL="false" DEFAULT="0"/>
                <FIELD NAME="group_id" TYPE="int" LENGTH="10" NOTNULL="false"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
            </KEYS>
        </TABLE>

        <TABLE NAME="local_moodec_transaction" COMMENT="Moodec transactions">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="txn_id" TYPE="char" LENGTH="255" NOTNULL="false" COMMENT="The transaction id from the payment gateway, e.g. PayPal"/>
                <FIELD NAME="user_id" TYPE="int" LENGTH="10" NOTNULL="false" COMMENT="The user ID who created the transaction"/>
                <FIELD NAME="gateway" TYPE="text" NOTNULL="false" COMMENT="The payment gateway"/>
                <FIELD NAME="status" TYPE="int" LENGTH="1" NOTNULL="false" DEFAULT="0" COMMENT="The transaction status"/>
                <FIELD NAME="purchase_date" TYPE="int" LENGTH="10" NOTNULL="false" COMMENT="Timestamp of the purchase"/>
                <FIELD NAME="error" TYPE="text" NOTNULL="false" COMMENT="Any error messages"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
            </KEYS>
        </TABLE>

        <TABLE NAME="local_moodec_trans_item" COMMENT="Moodec transaction items">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="transaction_id" TYPE="int" LENGTH="10" NOTNULL="false" COMMENT="Foreign key to transaction"/>
                <FIELD NAME="product_id" TYPE="int" LENGTH="10" NOTNULL="false" COMMENT="Moodec product ID"/>
                <FIELD NAME="variation_id" TYPE="int" LENGTH="10" NOTNULL="false" COMMENT="Moodec product variation ID"/>
                <FIELD NAME="item_cost" TYPE="number" LENGTH="10" DECIMALS="2" NOTNULL="false" COMMENT="Cost of item at transaction time"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
            </KEYS>
        </TABLE>
    </TABLES>
</XMLDB>
